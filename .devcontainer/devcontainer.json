// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Python + Node.js (optimized)",
	"image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
	
	// Forward ports for backend and frontend
	"forwardPorts": [8001, 5173, 5174],
	"portsAttributes": {
		"8001": {"label": "Backend API", "onAutoForward": "notify"},
		"5173": {"label": "Frontend Dev", "onAutoForward": "notify"},
		"5174": {"label": "Frontend Alt", "onAutoForward": "notify"}
	},
	
	// Enhanced postCreateCommand with Node.js and better optimization
	"postCreateCommand": "bash -c 'sudo apt-get update -y && sudo apt-get install -y ffmpeg libsm6 libxext6 libgl1-mesa-glx libglib2.0-0 libpq-dev gcc build-essential curl && curl -fsSL https://deb.nodesource.com/setup_18.x | sudo bash - && sudo apt-get install -y nodejs && pip install --index-url https://download.pytorch.org/whl/cpu torch torchvision && pip install -r requirements.txt'",
	
	// Increase container resources
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {}
	},
	
	// Customize terminal environment
	"remoteEnv": {
		"NODE_OPTIONS": "--max-old-space-size=4096",
		"PYTHONUNBUFFERED": "1"
	},
	
	// Configure VS Code settings
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"esbenp.prettier-vscode",
				"dbaeumer.vscode-eslint",
				"bradlc.vscode-tailwindcss"
			],
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python",
				"python.linting.enabled": true,
				"python.linting.pylintEnabled": true,
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode"
			}
		}
	}
}