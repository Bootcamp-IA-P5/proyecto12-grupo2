# PostgreSQL Configuration
POSTGRES_DB=brandtracker
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Backend FastAPI (puerto correcto)
BACKEND_URL=http://localhost:8001

# Frontend - IMPORTANTE: debe apuntar al puerto 8001
VITE_API_URL=http://localhost:8001
NODE_ENV=development

# Notas:
# - Este es el ÚNICO archivo .env del proyecto
# - El frontend usa un link simbólico a este archivo
# - NO crear archivos .env adicionales en /frontend
# - El backend FastAPI corre en puerto 8001, NO 8000
